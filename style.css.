*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: Arial, sans-serif;
}


body{
    background:#f4f4f4;
    color:#333;
}


/* Navigation */

header{
    background:#111;
    padding:20px 60px;
}


nav{
    display:flex;
    justify-content:space-between;
    align-items:center;
}


.logo{
    color:white;
    font-size:28px;
}


nav ul{
    list-style:none;
    display:flex;
    gap:30px;
}


nav ul li a{
    color:white;
    text-decoration:none;
    font-size:18px;
}


nav ul li a:hover{
    color:#00bcd4;
}



/* Hero section */

.hero{

    height:80vh;

    display:flex;
    justify-content:center;
    align-items:center;

    text-align:center;

    background:
    linear-gradient(
    rgba(0,0,0,0.5),
    rgba(0,0,0,0.5)
    );

}


.hero-content{

    max-width:700px;

    color:white;

}


.hero h1{

    font-size:55px;

    margin-bottom:20px;

}


.hero p{

    font-size:20px;

    line-height:1.6;

    margin-bottom:35px;

}



/* Button */

.btn{

    background:#00bcd4;

    color:white;

    padding:15px 35px;

    border-radius:30px;

    text-decoration:none;

    font-size:18px;

}


.btn:hover{

    background:#0097a7;

}



/* Footer */

footer{

    background:#111;

    color:white;

    text-align:center;

    padding:20px;

}
